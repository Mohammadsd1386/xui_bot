# ===== تنظیمات ربات تلگرام =====
# توکن ربات از @BotFather بگیرید
BOT_TOKEN=your_bot_token_here

# آیدی عددی ادمین‌ها (اگر چند ادمین: 123456,789012)
ADMIN_IDS=your_telegram_id_here

# ===== تنظیمات پنل 3x-ui =====
# آدرس کامل پنل (بدون / آخر)
PANEL_URL=http://your-server-ip:8080

# مسیر پنل (همان بخش رندوم URL)
PANEL_PATH=/UIsCCndjcqGPoV1RbI/panel

# یوزر و پسورد پنل
PANEL_USERNAME=admin
PANEL_PASSWORD=your_panel_password

# شناسه اینباند پیش‌فرض
DEFAULT_INBOUND_ID=1

# ===== تنظیمات پیش‌فرض کلاینت =====
DEFAULT_GB=10
DEFAULT_DAYS=30
DEFAULT_IP_LIMIT=2
